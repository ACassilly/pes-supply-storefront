# PES Supply — Environment Variables
# Copy to .env.local and fill in values
# All NEXT_PUBLIC_* vars are safe to expose to the browser

# ── Medusa
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.pes.supply
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_CHANGE_ME
NEXT_PUBLIC_MEDUSA_REGION=us
MEDUSA_ADMIN_API_KEY=sk_CHANGE_ME
MEDUSA_WEBHOOK_SECRET=CHANGE_ME

# ── Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Odoo
ODOO_URL=https://odoo.pes.supply
ODOO_DATABASE=pes_supply
ODOO_USERNAME=admin
ODOO_API_KEY=CHANGE_ME
SYNC_TO_ODOO=true
USE_ODOO_INVENTORY=true

# ── Site
NEXT_PUBLIC_SITE_URL=https://pes.supply

# ── Cache revalidation
REVALIDATE_SECRET=CHANGE_ME

# ── Google
GOOGLE_SITE_VERIFICATION=CHANGE_ME
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-CHANGE_ME

# ── Cloudflare (used by GitHub Actions)
CF_ZONE_ID=CHANGE_ME
CF_API_TOKEN=CHANGE_ME

# ── Azure VM (used by GitHub Actions deploy workflow)
AZURE_VM_HOST=CHANGE_ME
AZURE_VM_SSH_PRIVATE_KEY=CHANGE_ME

# ── Vercel (used by GitHub Actions)
VERCEL_TOKEN=CHANGE_ME
VERCEL_ORG_ID=CHANGE_ME
VERCEL_PROJECT_ID=CHANGE_ME
