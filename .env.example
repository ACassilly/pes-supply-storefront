# ============================================================
# PES Supply — Environment Variables
# Copy to .env.local for Codespace / local dev
# Set as GitHub Secrets for CI
# Set as App Settings on Azure App Service
# ============================================================

# --- Commerce provider ---
COMMERCE_PROVIDER=medusa
# options: medusa | shopify | odoo

# --- Site URL (changes per environment) ---
NEXT_PUBLIC_SITE_URL=https://pes.supply
# staging: https://staging.pes.supply
# local:   http://localhost:3000

# --- Medusa backend ---
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.pes.supply
# staging: https://api-staging.pes.supply
# local:   http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...
NEXT_PUBLIC_MEDUSA_REGION=us

# --- Odoo ERP ---
ODOO_URL=https://your-odoo.com
ODOO_DB=your_db
ODOO_USERNAME=api@pes.supply
ODOO_PASSWORD=
ODOO_API_KEY=

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# staging: pk_test_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Google ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
GOOGLE_SITE_VERIFICATION=
GOOGLE_MERCHANT_CENTER_ID=

# --- Cloudflare ---
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# --- ISR revalidation webhook secret ---
REVALIDATE_SECRET=change-me-strong-random-string

# --- App version (injected by CI) ---
NEXT_PUBLIC_APP_VERSION=dev

# --- Azure (used by deploy-azure.sh from Codespace) ---
AZURE_RESOURCE_GROUP=pes-supply-rg
AZURE_STAGING_APP=pes-supply-staging
AZURE_PRODUCTION_APP=pes-supply-production

# --- Vercel (fallback only — set as Codespace secrets) ---
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
