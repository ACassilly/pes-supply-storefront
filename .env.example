# =============================================================================
# PES Supply Storefront – Environment Variables
# Copy to .env.local and fill in real values. NEVER commit .env.local to git.
# =============================================================================

# ── Commerce Provider (shopify | medusa | odoo)
COMMERCE_PROVIDER=medusa

# ── Medusa Backend (primary for pes.supply)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.pes.supply
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxxxxxxxxxxx
NEXT_PUBLIC_MEDUSA_REGION=us

# ── Shopify (fallback / migration source)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_xxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10

# ── Odoo ERP Integration
ODOO_URL=https://odoo.pes.supply
ODOO_DATABASE=pes_supply
ODOO_USERNAME=api@pes.supply
ODOO_API_KEY=
USE_ODOO_INVENTORY=true
USE_ODOO_ORDERS=true
SYNC_TO_ODOO=true

# ── Stripe Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── Site / SEO
NEXT_PUBLIC_SITE_URL=https://pes.supply

# ── Google Integrations
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Vercel
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── Cloudflare
CF_ZONE_ID=
CF_API_TOKEN=

# ── Azure deployment target (used by CI/CD workflow)
AZURE_VM_HOST=
AZURE_VM_USER=pesadmin
# AZURE_VM_SSH_PRIVATE_KEY is stored as a GitHub Secret only – never here

# ── Email (transactional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
EMAIL_FROM=noreply@pes.supply
